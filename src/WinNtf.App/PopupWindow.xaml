<Window x:Class="WinNtf.App.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="win-ntf"
        Width="420"
        Height="105"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Border CornerRadius="14" Background="#F0101018" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.4" Color="Black" />
        </Border.Effect>
        <Grid>
            <Border x:Name="AccentBar" Width="5" HorizontalAlignment="Left" Background="#60A5FA" CornerRadius="14,0,0,14" />
            <Button x:Name="CloseButton"
                    Content="×"
                    Width="26"
                    Height="26"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,12,16,0"
                    Click="CloseButton_Click"
                    ToolTip="Close notification"
                    Focusable="False"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#BBBBBB"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Cursor="Hand" />
            <StackPanel Orientation="Horizontal" Margin="22,12,48,12" VerticalAlignment="Center">
                <TextBlock x:Name="IconText" Text="ℹ️" FontSize="30" VerticalAlignment="Center" Margin="0,0,15,0" />
                <StackPanel VerticalAlignment="Center" MaxWidth="300">
                    <TextBlock x:Name="TitleText" Text="win-ntf" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock x:Name="BodyText" Text="Local notifier" Foreground="#AAAAAA" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
