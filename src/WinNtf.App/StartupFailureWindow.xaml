<Window x:Class="WinNtf.App.StartupFailureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="win-ntf startup failed"
        Width="520"
        Height="180"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
    <StackPanel Margin="18">
        <TextBlock Text="win-ntf failed to start" FontSize="16" FontWeight="SemiBold" Foreground="#B91C1C" />
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" Margin="0,10,0,0" />
        <Button Content="Exit" Width="90" Margin="0,16,0,0" HorizontalAlignment="Left" Click="ExitClicked" />
    </StackPanel>
</Window>
